# ~/.deep-architect.toml — deep-architect configuration
# Copy to ~/.deep-architect.toml and fill in your model preferences.
#
# Endpoint and authentication are configured via environment variables:
#   ANTHROPIC_BASE_URL=http://litellm.cluster:9999
#   ANTHROPIC_AUTH_TOKEN=<your-api-key>
#   ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-standard
#   ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-standard
#   ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-standard
#   CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

[generator]
model                  = "sonnet"    # Model alias: "sonnet", "opus", "haiku", or full model ID
max_turns              = 50
max_agent_retries      = 2           # Retry the agent up to N times on CLI crash before failing
# context_window       = 200000      # Set to log context utilisation % on each tool call
# agent_timeout_seconds = 3600       # Per-attempt wall-clock limit in seconds (default 60 min); set to 0 or omit to disable

[critic]
model                  = "sonnet"
max_turns              = 30
max_agent_retries      = 2
# context_window       = 200000
# agent_timeout_seconds = 1800       # Critic is read-only and typically faster (default 30 min)

# Optional: override the claude CLI path (default: auto-detected from PATH).
# Use this if the bundled SDK binary ignores ANTHROPIC_BASE_URL.
# cli_path = "/home/gerald/.local/bin/claude"

[thresholds]
min_score                      = 9.0
consecutive_passing_rounds     = 2
max_rounds_per_sprint          = 6
max_total_rounds               = 40
timeout_hours                  = 0.0   # 0 = disabled; set to a positive value to enforce a wall-clock limit
ping_pong_similarity_threshold = 0.85
max_round_retries              = 2   # Retry a generator+critic round up to N times on failure
rollback_regression_threshold  = 0.05  # Roll back to best commit if score drops more than this below the best
